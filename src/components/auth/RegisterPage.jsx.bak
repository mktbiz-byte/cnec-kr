import React, { useState } from 'react';
import { useAuth } from '../../contexts/AuthContext';
import { useNavigate, Link } from 'react-router-dom';

const RegisterPage = () => {
  const { verifyBusinessNumber, signUpWithBusinessNumber } = useAuth();
  const navigate = useNavigate();
  const [password, setPassword] = useState('');
  const [confirmPassword, setConfirmPassword] = useState('');
  const [error, setError] = useState('');
  const [loading, setLoading] = useState(false);

  // 기업 정보
  const [businessInfo, setBusinessInfo] = useState({
    businessNumber: '', // 사업자등록번호 (아이디로 사용)
    startDate: '',      // 개업일자
    ownerName: '',      // 대표자명
    companyName: '',    // 회사명
    phoneNumber: '',    // 연락처
    address: '',        // 주소
  });
  const [verificationResult, setVerificationResult] = useState(null);
  const [step, setStep] = useState(1); // 1: 사업자 정보 입력, 2: 계정 정보 입력

  const handleBusinessInfoChange = (e) => {
    const { name, value } = e.target;
    setBusinessInfo({
      ...businessInfo,
      [name]: value,
    });
  };

  // 사업자등록번호 형식 변환 (000-00-00000)
  const formatBusinessNumber = (value) => {
    const numbers = value.replace(/[^0-9]/g, '');
    if (numbers.length <= 3) return numbers;
    if (numbers.length <= 5) return `${numbers.slice(0, 3)}-${numbers.slice(3)}`;
    return `${numbers.slice(0, 3)}-${numbers.slice(3, 5)}-${numbers.slice(5, 10)}`;
  };

  // 사업자등록번호 입력 처리
  const handleBusinessNumberChange = (e) => {
    const formattedValue = formatBusinessNumber(e.target.value);
    setBusinessInfo({
      ...businessInfo,
      businessNumber: formattedValue,
    });
  };

  // 개업일자 형식 변환 (YYYY-MM-DD)
  const formatStartDate = (value) => {
    const numbers = value.replace(/[^0-9]/g, '');
    if (numbers.length <= 4) return numbers;
    if (numbers.length <= 6) return `${numbers.slice(0, 4)}-${numbers.slice(4)}`;
    return `${numbers.slice(0, 4)}-${numbers.slice(4, 6)}-${numbers.slice(6, 8)}`;
  };

  // 개업일자 입력 처리
  const handleStartDateChange = (e) => {
    const formattedValue = formatStartDate(e.target.value);
    setBusinessInfo({
      ...businessInfo,
      startDate: formattedValue,
    });
  };

  // 사업자 정보 검증
  const handleVerification = async () => {
    setLoading(true);
    setError('');
    
    // 입력값 검증
    if (!businessInfo.businessNumber || !businessInfo.startDate || !businessInfo.ownerName) {
      setError('사업자등록번호, 개업일자, 대표자명을 모두 입력해주세요.');
      setLoading(false);
      return;
    }
    
    try {
      // API 요청을 위해 형식 변환
      const apiBusinessInfo = {
        b_no: businessInfo.businessNumber.replace(/-/g, ''),
        start_dt: businessInfo.startDate.replace(/-/g, ''),
        p_nm: businessInfo.ownerName,
      };
      
      const result = await verifyBusinessNumber(apiBusinessInfo);
      setVerificationResult(result);
      
      if (result.valid) {
        setStep(2); // 다음 단계로 이동
      } else {
        setError(result.message);
      }
    } catch (error) {
      setError('사업자등록정보 확인 중 오류가 발생했습니다.');
      console.error(error);
    }
    
    setLoading(false);
  };

  // 회원가입 제출
  const handleSubmit = async (e) => {
    e.preventDefault();
    setError('');
    
    // 비밀번호 검증
    if (password !== confirmPassword) {
      setError('비밀번호가 일치하지 않습니다.');
      return;
    }
    
    if (password.length < 8) {
      setError('비밀번호는 8자 이상이어야 합니다.');
      return;
    }
    
    setLoading(true);
    
    try {
      // 사업자등록번호를 아이디로 사용
      const { success, message } = await signUpWithBusinessNumber(
        businessInfo.businessNumber.replace(/-/g, ''),
        password,
        {
          companyName: businessInfo.companyName,
          representativeName: businessInfo.ownerName,
          startDate: businessInfo.startDate.replace(/-/g, ''),
          phoneNumber: businessInfo.phoneNumber,
          address: businessInfo.address,
        }
      );
      
      if (success) {
        // 회원가입 성공 시 로그인 페이지로 이동
        navigate('/auth/login', { 
          state: { 
            message: '회원가입이 완료되었습니다. 관리자 승인 후 로그인이 가능합니다.' 
          } 
        });
      } else {
        setError(message || '회원가입 중 오류가 발생했습니다.');
      }
    } catch (error) {
      setError(error.message || '회원가입 중 오류가 발생했습니다.');
    }
    
    setLoading(false);
  };

  return (
    <div className="auth-layout">
      <div className="auth-container">
        <div className="auth-card">
          <h2 className="page-title">기업 회원가입</h2>
          
          {error && <div className="error-message">{error}</div>}
          
          {step === 1 ? (
            // 1단계: 사업자 정보 입력
            <div className="step-container">
              <div className="step-indicator">
                <div className="step active">1. 사업자 정보 확인</div>
                <div className="step">2. 계정 정보 입력</div>
              </div>
              
              <div className="form-group">
                <label htmlFor="businessNumber">사업자등록번호</label>
                <input
                  type="text"
                  id="businessNumber"
                  name="businessNumber"
                  className="form-control"
                  value={businessInfo.businessNumber}
                  onChange={handleBusinessNumberChange}
                  placeholder="000-00-00000"
                  maxLength={12}
                  required
                />
              </div>
              
              <div className="form-group">
                <label htmlFor="startDate">개업일자</label>
                <input
                  type="text"
                  id="startDate"
                  name="startDate"
                  className="form-control"
                  value={businessInfo.startDate}
                  onChange={handleStartDateChange}
                  placeholder="YYYY-MM-DD"
                  maxLength={10}
                  required
                />
              </div>
              
              <div className="form-group">
                <label htmlFor="ownerName">대표자명</label>
                <input
                  type="text"
                  id="ownerName"
                  name="ownerName"
                  className="form-control"
                  value={businessInfo.ownerName}
                  onChange={handleBusinessInfoChange}
                  required
                />
              </div>
              
              <button
                type="button"
                className="btn-primary"
                onClick={handleVerification}
                disabled={loading}
              >
                {loading ? '확인 중...' : '사업자 정보 확인'}
              </button>
              
              <div className="auth-links">
                <p>
                  이미 계정이 있으신가요? <Link to="/auth/login">로그인</Link>
                </p>
              </div>
            </div>
          ) : (
            // 2단계: 계정 정보 입력
            <form onSubmit={handleSubmit} className="step-container">
              <div className="step-indicator">
                <div className="step completed">1. 사업자 정보 확인</div>
                <div className="step active">2. 계정 정보 입력</div>
              </div>
              
              <div className="verification-success">
                <div className="success-icon">✓</div>
                <p>사업자 정보가 확인되었습니다.</p>
              </div>
              
              <div className="form-group">
                <label htmlFor="businessNumber">아이디 (사업자등록번호)</label>
                <input
                  type="text"
                  id="businessNumber"
                  className="form-control"
                  value={businessInfo.businessNumber}
                  disabled
                />
                <small>* 사업자등록번호가 아이디로 사용됩니다.</small>
              </div>
              
              <div className="form-group">
                <label htmlFor="companyName">회사명</label>
                <input
                  type="text"
                  id="companyName"
                  name="companyName"
                  className="form-control"
                  value={businessInfo.companyName}
                  onChange={handleBusinessInfoChange}
                  required
                />
              </div>
              
              <div className="form-group">
                <label htmlFor="phoneNumber">연락처</label>
                <input
                  type="text"
                  id="phoneNumber"
                  name="phoneNumber"
                  className="form-control"
                  value={businessInfo.phoneNumber}
                  onChange={handleBusinessInfoChange}
                  placeholder="010-0000-0000"
                  required
                />
              </div>
              
              <div className="form-group">
                <label htmlFor="address">주소</label>
                <input
                  type="text"
                  id="address"
                  name="address"
                  className="form-control"
                  value={businessInfo.address}
                  onChange={handleBusinessInfoChange}
                  required
                />
              </div>
              
              <div className="form-group">
                <label htmlFor="password">비밀번호</label>
                <input
                  type="password"
                  id="password"
                  className="form-control"
                  value={password}
                  onChange={(e) => setPassword(e.target.value)}
                  minLength={8}
                  required
                />
                <small>* 8자 이상 입력해주세요.</small>
              </div>
              
              <div className="form-group">
                <label htmlFor="confirmPassword">비밀번호 확인</label>
                <input
                  type="password"
                  id="confirmPassword"
                  className="form-control"
                  value={confirmPassword}
                  onChange={(e) => setConfirmPassword(e.target.value)}
                  minLength={8}
                  required
                />
              </div>
              
              <div className="form-actions">
                <button
                  type="button"
                  className="btn-secondary"
                  onClick={() => setStep(1)}
                  disabled={loading}
                >
                  이전
                </button>
                <button
                  type="submit"
                  className="btn-primary"
                  disabled={loading}
                >
                  {loading ? '가입 중...' : '회원가입'}
                </button>
              </div>
            </form>
          )}
        </div>
      </div>
    </div>
  );
};

export default RegisterPage;
